rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function adminDocPath(uid) {
      return /databases/$(database)/documents/admin_users/$(uid);
    }

    function adminDoc() {
      return get(adminDocPath(request.auth.uid));
    }

    function isAdminUser() {
      return isAuthenticated() &&
        exists(adminDocPath(request.auth.uid)) &&
        adminDoc().data.role == 'admin' &&
        adminDoc().data.isActive == true &&
        adminDoc().data.isLocked == false;
    }

    function isSuperAdmin() {
      return isAdminUser() &&
        adminDoc().data.accessLevel == 'super_admin';
    }

    function isOwnAdminProfile(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isConversationParticipant() {
      return isAuthenticated() &&
        resource.data.participantUid == request.auth.uid;
    }

    // Admin Users Collection - locked down to authenticated admin identities only.
    // Initial bootstrap should happen out-of-band with Firebase Admin SDK or console access.
    match /admin_users/{userId} {
      allow create: if isSuperAdmin() &&
        request.resource.data.role == 'admin' &&
        request.resource.data.createdBy == request.auth.uid;

      allow get: if isOwnAdminProfile(userId) || isSuperAdmin();
      allow list: if isSuperAdmin();

      allow update: if
        (
          isOwnAdminProfile(userId) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'lastActivity',
            'lastLogin',
            'loginAttempts',
            'avatar',
            'name'
          ]) &&
          request.resource.data.role == resource.data.role &&
          request.resource.data.accessLevel == resource.data.accessLevel &&
          request.resource.data.permissions == resource.data.permissions &&
          request.resource.data.isActive == resource.data.isActive &&
          request.resource.data.isLocked == resource.data.isLocked
        ) ||
        (
          isSuperAdmin() &&
          request.auth.uid != userId
        );

      allow delete: if isSuperAdmin() && request.auth.uid != userId;
    }

    match /admin_audit_logs/{logId} {
      allow read: if isAdminUser();
      allow create: if isAdminUser();
      allow update, delete: if false;
    }

    match /tracking_items/{trackingId} {
      allow read: if isAdminUser();
      allow create, update: if isAdminUser();
      allow delete: if isSuperAdmin();
    }

    match /public_tracking_items/{trackingId} {
      allow read: if true;
      allow create, update, delete: if isAdminUser();
    }

    match /tracking_items/{trackingId}/status_updates/{updateId} {
      allow read: if isAdminUser();
      allow create, update: if isAdminUser();
      allow delete: if isSuperAdmin();
    }

    match /tracking_notifications/{notificationId} {
      allow read, create, update: if isAdminUser();
      allow delete: if isSuperAdmin();
    }

    match /system_counters/{counterId} {
      allow read, create, update: if isAdminUser();
      allow delete: if isSuperAdmin();
    }

    match /admin_sessions/{sessionId} {
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
      allow get, list, update: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
      allow delete: if isSuperAdmin();
    }

    match /users/{userId} {
      allow read, create, update, delete: if isAdminUser();
    }

    match /tracking_numbers/{trackingId} {
      allow read, create, update, delete: if isAdminUser();
    }

    match /audit_logs/{logId} {
      allow read, create: if isAdminUser();
      allow update, delete: if false;
    }

    match /system_settings/{settingId} {
      allow read: if isAdminUser();
      allow write: if isSuperAdmin();
    }

    match /reports/{reportId} {
      allow read, create: if isAdminUser();
      allow update, delete: if isSuperAdmin();
    }

    // Public quote submission remains allowed, but quote data is no longer public.
    match /quotes/{quoteId} {
      allow create: if true;
      allow read, update: if isAdminUser();
      allow delete: if isSuperAdmin();
    }

    // Chat conversations are accessible to the authenticated participant or admins.
    match /chat_conversations/{conversationId} {
      allow create: if isAuthenticated() &&
        request.resource.data.participantUid == request.auth.uid;
      allow read: if isAdminUser() || isConversationParticipant();
      allow update: if isAdminUser() || isConversationParticipant();
      allow delete: if isAdminUser();
    }

    match /chat_messages/{messageId} {
      allow create: if
        (
          isAuthenticated() &&
          request.resource.data.sender == 'user' &&
          exists(/databases/$(database)/documents/chat_conversations/$(request.resource.data.conversationId)) &&
          get(/databases/$(database)/documents/chat_conversations/$(request.resource.data.conversationId)).data.participantUid == request.auth.uid
        ) ||
        (
          isAdminUser() &&
          request.resource.data.sender == 'admin'
        );
      allow read: if isAdminUser() ||
        (
          isAuthenticated() &&
          exists(/databases/$(database)/documents/chat_conversations/$(resource.data.conversationId)) &&
          get(/databases/$(database)/documents/chat_conversations/$(resource.data.conversationId)).data.participantUid == request.auth.uid
        );
      allow update: if isAdminUser() ||
        (
          isAuthenticated() &&
          exists(/databases/$(database)/documents/chat_conversations/$(resource.data.conversationId)) &&
          get(/databases/$(database)/documents/chat_conversations/$(resource.data.conversationId)).data.participantUid == request.auth.uid
        );
      allow delete: if isAdminUser();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
